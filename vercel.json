{
  "version": 2,
  "buildCommand": "npm install",
  "outputDirectory": "client/dist",
  "framework": "vite",
  "functions": {
    "server/api/handler.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/api/handler.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/dist/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
